{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-supermemory"],
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "question": "allow",
    "todowrite": "allow",
    "list": "allow",
    "edit": "ask",
    "write": "ask",
    "bash": "ask",
    "skill": {
      "*": "ask",
      "writing-plans": "allow",
      "dispatching-parallel-agents": "allow",
      "brainstorming": "allow",
      "finishing-a-development-branch": "allow",
      "code-review": "allow",
      "systematic-debugging": "allow",
      "using-superpowers": "allow",
    },
  },
  "tools": {
    "skill": true,
  },
  "lsp": {
    "rust": {
      "command": ["rust-analyzer"],
      "env": {
        "RUST_LOG": "debug",
      },
    },
    "qml": {
      "command": ["qmlls6"],
      "extensions": [".qml", ".qmljs", ".qml.js"],
    },
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000,
  },
  "agent": {
    "build": {
      "permission": {
        "edit": "allow",
        "write": "allow",
      },
    },
    "qt-dev": {
      "description": "Qt/QML/QuickShell Developer agent",
      "mode": "primary",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "color": "#ffea98",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "cargo build *": "allow",
          "cmake *": "allow",
          "make *": "allow",
          "cmake --build *": "allow",
        },
        "skill": {
          "*": "ask",
          "code-review": "allow",
          "systematic-debugging": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/qml.instructions.md}\n\n{file:./instructions/quickshell.instructions.md}",
    },
    "rust-dev": {
      "description": "Rust Developer agent (standalone - use rust-orchestrator for multi-agent workflow)",
      "mode": "primary",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "ask",
        "write": "ask",
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "cargo format --check": "allow",
          "cargo build *": "allow",
          "cargo test *": "allow",
          "cargo clippy *": "allow",
        },
        "skill": {
          "*": "allow",
          "test-driven-development": "allow",
          "verification-before-completion": "allow",
          "code-review": "allow",
          "systematic-debugging": "allow",
          "brainstorming": "allow",
          "writing-plans": "allow",
          "using-superpowers": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/rust/rust.instructions.md}\n\n{file:./instructions/rust/rust-antipatterns.instructions.md}",
    },
  },
}
