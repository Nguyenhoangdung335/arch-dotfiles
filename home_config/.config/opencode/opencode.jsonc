{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "general-orchestrator",
  "plugin": ["opencode-supermemory"],
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "question": "allow",
    "todowrite": "allow",
    "list": "allow",
    "edit": "ask",
    "write": "ask",
    "bash": "ask",
    "skill": {
      "*": "ask",
      "writing-plans": "allow",
      "dispatching-parallel-agents": "allow",
      "brainstorming": "allow",
      "finishing-a-development-branch": "allow",
      "code-review": "allow",
      "systematic-debugging": "allow",
      "using-superpowers": "allow",
    },
  },
  "tools": {
    "skill": true,
  },
  "lsp": {
    "rust": {
      "command": ["rust-analyzer"],
      "env": {
        "RUST_LOG": "debug",
      },
    },
    "qml": {
      "command": ["qmlls6"],
      "extensions": [".qml", ".qmljs", ".qml.js"],
    },
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000,
  },
  "agent": {
    "build": {
      "permission": {
        "edit": "allow",
        "write": "allow",
      },
    },
    "qt-dev": {
      "description": "Qt/QML/QuickShell Developer agent",
      "mode": "primary",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "color": "#ffea98",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "cargo build *": "allow",
          "cmake *": "allow",
          "make *": "allow",
          "cmake --build *": "allow",
        },
        "skill": {
          "*": "ask",
          "code-review": "allow",
          "systematic-debugging": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/qml.instructions.md}\n\n{file:./instructions/quickshell.instructions.md}",
    },
    "rust-debugger": {
      "description": "Rust debugger - methodical, forensic investigation of bugs. Hypothesis-driven root cause analysis.",
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "color": "#E74C3C",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "ask",
        "write": "deny",
        "bash": {
          "*": "allow",
          "cargo check *": "allow",
        },
        "skill": {
          "*": "allow",
          "systematic-debugging": "allow",
          "verification-before-completion": "allow",
          "using-superpowers": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/rust/rust-debugger.instructions.md}",
    },
    "rust-dev": {
      "description": "Rust Developer agent (standalone - use rust-orchestrator for multi-agent workflow)",
      "mode": "primary",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "ask",
        "write": "ask",
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "cargo format --check": "allow",
          "cargo build *": "allow",
          "cargo test *": "allow",
          "cargo clippy *": "allow",
        },
        "skill": {
          "*": "allow",
          "test-driven-development": "allow",
          "verification-before-completion": "allow",
          "code-review": "allow",
          "systematic-debugging": "allow",
          "brainstorming": "allow",
          "writing-plans": "allow",
          "using-superpowers": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/rust/rust.instructions.md}\n\n{file:./instructions/rust/rust-antipatterns.instructions.md}",
    },
    "rust-developer": {
      "description": "Rust developer - writes code, implements features, fixes bugs. Reports results to orchestrator.",
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "color": "#E67E22",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "allow",
        },
        "skill": {
          "*": "allow",
          "test-driven-development": "allow",
          "verification-before-completion": "allow",
          "code-review": "allow",
          "systematic-debugging": "allow",
          "brainstorming": "allow",
          "using-superpowers": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/rust/rust.instructions.md}\n\n{file:./instructions/rust/rust-antipatterns.instructions.md}",
    },
    "rust-explorer": {
      "description": "Rust codebase explorer - fast, read-only file and code search. Scouts, finds, reports. Never modifies files.",
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "color": "#3498DB",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "git log *": "allow",
          "cargo tree *": "allow",
        },
        "skill": {
          "*": "deny",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/rust/rust-explorer.instructions.md}",
    },
    "rust-orchestrator": {
      "description": "Rust team lead - plans, delegates, reviews. Never writes code directly.",
      "mode": "primary",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "temperature": 0.3,
      "color": "#ffea98",
      "permission": {
        "read": "ask",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "git show *": "allow",
          "git branch *": "allow",
        },
        "skill": {
          "*": "ask",
          "find-skills": "allow",
          "subagent-driven-development": "allow",
          "writing-plans": "allow",
          "dispatching-parallel-agents": "allow",
          "brainstorming": "allow",
          "finishing-a-development-branch": "allow",
          "code-review": "allow",
          "systematic-debugging": "allow",
          "using-superpowers": "allow",
          "executing-plans": "allow",
        },
        "task": {
          "*": "ask",
          "rust-planner": "allow",
          "rust-developer": "allow",
          "rust-debugger": "allow",
          "rust-security": "allow",
          "rust-reviewer": "allow",
          "rust-explorer": "allow",
          "rust-qc": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/rust/rust-orchestrator.instructions.md}",
    },
    "rust-planner": {
      "description": "Rust planner - plans features, researches the Rust ecosystem (crates.io, docs.rs), gets new info on the internet. Emphasizes renewing knowledge.",
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "color": "#8E44AD",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "websearch": "allow",
        "webfetch": "allow",
        "edit": "allow",
        "write": "allow",
        "question": "allow",
        "bash": {
          "*": "ask",
          "cargo search *": "allow",
        },
        "skill": {
          "brainstorming": "allow",
          "writing-plans": "allow",
          "using-superpowers": "allow",
          "*": "allow",
        },
      },
      "tools": {
        "skill": true,
        "question": true,
      },
      "prompt": "{file:./instructions/rust/rust-planner.instructions.md}",
    },
    "rust-qc": {
      "description": "Rust quality control - paranoid test case generator. Questions everything, finds edge cases, generates comprehensive test coverage.",
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "temperature": 0.2,
      "color": "#F39C12",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "ask",
        "write": "ask",
        "bash": {
          "cargo test *": "allow",
          "cargo check *": "allow",
          "git status *": "allow",
          "*": "ask",
        },
        "skill": {
          "test-driven-development": "allow",
          "verification-before-completion": "allow",
          "code-review": "allow",
          "using-superpowers": "allow",
          "*": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/rust/rust-qc.instructions.md}",
    },
    "rust-reviewer": {
      "description": "Rust code reviewer - constructive but strict. Catches anti-patterns, checks API design, suggests idioms.",
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "temperature": 0.1,
      "color": "#27AE60",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "git status *": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "cargo clippy *": "allow",
          "cargo fmt --check *": "allow",
          "cargo check *": "allow",
          "cat *": "allow",
          "*": "ask",
        },
        "skill": {
          "code-review": "allow",
          "verification-before-completion": "allow",
          "using-superpowers": "allow",
          "*": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/rust/rust-reviewer.instructions.md}\n\n{file:./instructions/rust/rust-antipatterns.instructions.md}",
    },
    "rust-security": {
      "description": "Rust security auditor - paranoid, adversarial analysis. Checks unsafe code, dependencies, memory safety, input validation.",
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "color": "#9B59B6",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "git status *": "allow",
          "git diff *": "allow",
          "cargo check *": "allow",
          "cargo audit *": "allow",
          "cargo tree *": "allow",
          "*": "ask",
        },
        "skill": {
          "code-review": "allow",
          "verification-before-completion": "allow",
          "using-superpowers": "allow",
          "*": "allow",
        },
      },
      "tools": {
        "skill": true,
      },
      "prompt": "{file:./instructions/rust/rust-security.instructions.md}",
    },
    "general-orchestrator": {
      "description": "General team lead - plans, delegates, reviews. Never writes code directly.",
      "mode": "primary",
