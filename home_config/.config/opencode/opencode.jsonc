      "description": "General developer - writes code, implements features, fixes bugs. Reports results to orchestrator.",
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "color": "#E67E22",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
