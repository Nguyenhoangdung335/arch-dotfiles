          "*": "ask",
          "find-skills": "allow",
          "skill-creator": "allow",
          "qt-qml-development": "allow",
          "subagent-driven-development": "allow",
          "writing-plans": "allow",
          "dispatching-parallel-agents": "allow",
          "brainstorming": "allow",
          "finishing-a-development-branch": "allow",
          "code-review": "allow",
          "systematic-debugging": "allow",
          "using-superpowers": "allow",
          "executing-plans": "allow",
        },
      },
      "task": {
        "*": "ask",
        "general-planner": "allow",
        "general-developer": "allow",
        "general-debugger": "allow",
        "general-security": "allow",
        "general-reviewer": "allow",
        "general-explorer": "allow",
        "general-qc": "allow",
      },
      "prompt": "{file:./instructions/general/general-orchestrator.instructions.md}",
    },
    "general-planner": {
      "description": "General planner - plans features, researches, gets new info on the internet. Emphasizes renewing knowledge.",
      "mode": "subagent",
      "model": "github-copilot/gemini-3.1-pro-preview",
      "color": "#8E44AD",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "websearch": "allow",
        "webfetch": "allow",
        "edit": "allow",
        "write": "allow",
