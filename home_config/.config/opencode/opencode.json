{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "qt-dev": {
      "mode": "primary",
      "description": "Qt/QML/QuickShell Developer agent",
      "prompt": "{file:./instructions/qml.instructions.md} {file:./instructions/quickshell.instructions.md} {file:./instructions/debug.instructions.md} {file:./instructions/security.instructions.md}",
      "instructions": [
        "qml.instructions.md",
        "quickshell.instructions.md",
        "debug.instructions.md",
        "security.instructions.md"
      ],
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "cargo build *": "allow",
          "cmake *": "allow",
          "make *": "allow",
          "cmake --build *": "allow"
        },
        "skill": {
          "code-review": "allow",
          "systematic-debugging": "allow",
          "*": "ask"
        }
      },
      "tools": {
        "skill": true
      },
      "model": "github-copilot/gemini-3.1-pro-preview"
    },
    "rust-dev": {
      "mode": "primary",
      "description": "Rust Developer agent",
      "prompt": "{file:./instructions/rust.instructions.md} {file:./instructions/debug.instructions.md} {file:./instructions/security.instructions.md}",
      "instructions": [
        "rust.instructions.md",
        "debug.instructions.md",
        "security.instructions.md"
      ],
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "ask",
        "write": "ask",
        "bash": {
          "*": "ask",
          "git status *": "allow",
          "cargo format --check": "allow"
        },
        "skill": {
          "code-review": "allow",
          "*": "ask"
        }
      },
      "tools": {
        "skill": true
      },
      "model": "github-copilot/gemini-3.1-pro-preview"
    }
  }
}
