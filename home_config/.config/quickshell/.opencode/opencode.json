{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["qml.instructions.md", "quickshell.instructions.md"],
  "agent": {
    "mentor": {
      "mode": "primary",
      "description": "Educational mentor agent",
      "prompt": "{file:./EDUCATIONAL_AGENTS.md} {file:./ARCHITECTURE_INTENT.md}",
      "instructions": ["EDUCATIONAL_AGENTS.md", "ARCHITECTURE_INTENT.md"],
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "ask",
        "write": "ask",
        "bash": {
          "*": "ask",
          "git status *": "allow"
        }
      },
      "model": "github-copilot/gemini-3.1-pro-preview"
    },
    "implementer": {
      "mode": "primary",
      "description": "Implementation agent (writes code when explicitly requested)",
      "prompt": "{file:./ARCHITECTURE_INTENT.md}",
      "instructions": ["ARCHITECTURE_INTENT.md"],
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "ask",
          "git status *": "allow"
        }
      },
      "model": "github-copilot/gemini-3.1-pro-preview"
    }
  },
  "default_agent": "mentor"
}
